# ============================================================
# Browser AI Coding Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---- Frontend (Vite) ----------------------------------------------
# Gemini API key — only needed when NOT using the Spring Boot backend.
# When the backend is running, set GEMINI_API_KEY on the server instead.
VITE_GEMINI_API_KEY=your_gemini_pro_api_key_here

# URL of the Spring Boot backend (default: http://localhost:8080)
VITE_BACKEND_URL=http://localhost:8080

# ---- Backend: Database (PostgreSQL) --------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/browserai
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# ---- Backend: Redis ------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Backend: JWT --------------------------------------------------
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ---- Backend: Gemini -----------------------------------------------
GEMINI_API_KEY=your_gemini_pro_api_key_here

# ---- Backend: Deployment APIs --------------------------------------
VERCEL_TOKEN=
GITHUB_TOKEN=

# ---- Backend: Stripe (optional future monetisation) ----------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
